{
  "title": "Business Analytics",
  "uid": "business-analytics",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "1m",
  "schemaVersion": 38,
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Total Users Active",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT user_id) FROM analytics_events;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Successful Plans Generated",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM analytics_events WHERE event_name = 'plan_generated' AND properties->>'success' = 'true';",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Plan Exports",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM analytics_events WHERE event_name = 'plan_exported';",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "piechart",
      "title": "Plan Generation Success Rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT properties->>'success' as success, COUNT(*) as count FROM analytics_events WHERE event_name = 'plan_generated' GROUP BY 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "right"
        }
      }
    },
    {
      "type": "piechart",
      "title": "Action Breakdown (excl. Page Views)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT event_name, COUNT(*) as count FROM analytics_events WHERE event_name != 'page_view' GROUP BY event_name;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "right"
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Most Read Knowledge Topics",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT properties->>'topic' as topic, COUNT(*) as count FROM analytics_events WHERE event_name = 'knowledge_card_clicked' GROUP BY 1 ORDER BY 2 DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "bottom"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Daily Action Volume (excl. Page Views)",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "uphill-postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(timestamp, '1d') as time, event_name as metric, COUNT(*) as value FROM analytics_events WHERE event_name != 'page_view' GROUP BY 1, 2 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    }
  ]
}