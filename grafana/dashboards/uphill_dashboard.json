{
  "uid": "uphill-ai-main",
  "title": "Uphill AI Observability",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "API Traffic (Count & RPS)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total Requests"
        },
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "Current RPS (5m)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Avg NotebookLM Latency",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(notebooklm_latency_seconds_sum[5m])) / sum(rate(notebooklm_latency_seconds_count[5m]))",
          "legendFormat": "Global Avg Latency (5m)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Traffic (RPS)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, handler)",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "NotebookLM Latency (Excluding Cache)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(notebooklm_latency_seconds_sum[1m]) / rate(notebooklm_latency_seconds_count[1m])",
          "legendFormat": "{{service}} Avg Latency"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens Sent to NotebookLM",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(notebooklm_tokens_sent_total)",
          "legendFormat": "Sent Tokens"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens Received from NotebookLM",
      "gridPos": {
        "x": 6,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(notebooklm_tokens_received_total)",
          "legendFormat": "Received Tokens"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Usage Rate (per sec)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(notebooklm_tokens_sent_total[1m])) by (service)",
          "legendFormat": "{{service}} Sent"
        },
        {
          "expr": "sum(rate(notebooklm_tokens_received_total[1m])) by (service)",
          "legendFormat": "{{service}} Received"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node Memory Usage",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "title": "NotebookLM Attempts",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(notebooklm_attempts_total{status=\"success\"})",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(notebooklm_attempts_total{status=\"error\"})",
          "legendFormat": "Error",
          "refId": "B"
        },
        {
          "expr": "sum(notebooklm_attempts_total{status=\"attempt\"})",
          "legendFormat": "Attempted",
          "refId": "C"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    }
  ]
}
